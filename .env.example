# Dành cho hệ điều hành Windows: Chỉnh sửa đường dẫn này nếu bạn cài ImageMagick ở ổ đĩa khác
# (Ví dụ: C:\Program Files\ImageMagick-7.1.1-Q16-HDRI\magick.exe)
IMAGEMAGICK_BINARY=C:\Program Files\ImageMagick-7.1.1-Q16-HDRI\magick.exe
